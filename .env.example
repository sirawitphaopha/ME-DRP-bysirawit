# คัดลอกเป็น .env.local แล้วใส่ค่าจริง
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# ทั้งสองค่านี้เป็นค่า default ตอน build
# ผู้ใช้ยังตั้ง URL/key เองได้ที่หน้า "ตั้งค่า" (เก็บใน localStorage) หรือปล่อยว่างเพื่อรันโหมด demo
